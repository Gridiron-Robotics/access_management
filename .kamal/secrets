# Kamal secrets. This file is committed as a TEMPLATE only.
#
# DO NOT put real secret values here. Each entry below is interpolated from your
# shell environment (CI secrets, a vault, 1Password, etc.) at deploy time, e.g.:
#
#   export KAMAL_REGISTRY_PASSWORD=ghp_xxx
#   bundle exec kamal deploy
#
# Docs: https://kamal-deploy.org/docs/commands/secrets/
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

